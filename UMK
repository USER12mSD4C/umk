# ==============================================
# Тестовый UMK файл (без создания файлов)
# ==============================================

# Переменные
MSG = Hello from variable!
WILD_SRC = $(wildcard *.c)
SHELL_DATE = $(shell date +%Y-%m-%d)

# 1. Проверка переменных и функций
test_vars:
	echo "MSG = $(MSG)"
	echo "WILD_SRC = $(WILD_SRC)"
	echo "SHELL_DATE = $(SHELL_DATE)"
eoc

# 2. Проверка цепочки зависимостей (виртуальные цели)
dep1:
	echo "Building dep1"
eoc

dep2:
	echo "Building dep2"
eoc

test_deps: dep1 dep2
	echo "test_deps finished"
eoc

# 3. Автоматические переменные (работают в контексте правил)
# Для их проверки нужны "реальные" файлы, но мы обойдёмся без создания:
# Используем существующие файлы (например сам UMK) как зависимости.
test_autovars: UMK Makefile
	echo "Target: $@"
	echo "First dep: $<"
	echo "All deps: $^"
eoc

# 4. Шаблонное правило (без создания файлов)
# Просто печатает, что должно было бы произойти.
%.fake: %.src
	echo "Pattern rule triggered: target=$@, source=$<"
eoc

# Подготовим файл-источник (без реального создания, просто echo)
dummy.src:
	echo "This is dummy.src content (simulated)"
eoc

test_pattern: dummy.fake
	echo "Pattern test done"
eoc

# 5. Проверка команд (call) и флагов
test_call:
	echo "This is a command"
	call test_vars
eoc
flag:
    echo "shi its message"
    +flags:
    -fg(before_flag)
	    echo "Before command flag executed"
    eofg
    +fg(after_flag)
	    echo "After command flag executed"
    eofg
    ;
eoc

test_flags:
	echo "Main command of test_flags"
eoc

# 6. Цель по умолчанию (запустит все проверки)
all: test_vars test_deps test_autovars test_pattern test_call test_flags
	echo "All tests passed!"
eoc
